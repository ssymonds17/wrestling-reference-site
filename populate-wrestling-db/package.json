{
  "name": "populate-wrestling-db",
  "version": "0.1.0",
  "description": "Ingest wrestling data (promotions, wrestlers, matches) from CSV via the wrestling-api endpoints",
  "type": "module",
  "scripts": {
    "populate:promotions": "node populatePromotions.mjs",
    "populate:wrestlers": "node populateWrestlers.mjs",
    "populate:matches": "node populateMatches.mjs",
    "recompute:years": "node recomputeWrestlerYears.mjs",
    "recompute:careers": "node recomputeCareerScores.mjs"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
