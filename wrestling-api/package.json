{
  "name": "wrestling-api",
  "version": "0.1.0",
  "bin": {
    "wrestling-api": "bin/wrestling-api.js"
  },
  "scripts": {
    "build:all": "npm run build:create-wrestler && npm run build:get-wrestlers && npm run build:get-wrestler-by-id && npm run build:update-wrestler && npm run build:delete-wrestler && npm run build:recompute-wrestler && npm run build:create-promotion && npm run build:get-promotions && npm run build:get-promotion-by-id && npm run build:update-promotion && npm run build:delete-promotion && npm run build:search && npm run build:create-match && npm run build:get-matches && npm run build:get-match-by-id && npm run build:delete-match && npm run build:update-match && npm run build:update-participant-rating && npm run build:update-overall-match-rating && npm run build:get-wrestler-years && npm run build:get-year-standings && npm run build:get-years && npm run build:assign-tier && npm run build:recompute-wrestler-year && npm run build:recompute-career-score && npm run build:get-career-leaderboard",
    "build:create-wrestler": "esbuild lambda/create-wrestler.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/create-wrestler/index.js",
    "build:get-wrestlers": "esbuild lambda/get-wrestlers.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/get-wrestlers/index.js",
    "build:get-wrestler-by-id": "esbuild lambda/get-wrestler-by-id.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/get-wrestler-by-id/index.js",
    "build:update-wrestler": "esbuild lambda/update-wrestler.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/update-wrestler/index.js",
    "build:delete-wrestler": "esbuild lambda/delete-wrestler.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/delete-wrestler/index.js",
    "build:recompute-wrestler": "esbuild lambda/recompute-wrestler.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/recompute-wrestler/index.js",
    "build:create-promotion": "esbuild lambda/create-promotion.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/create-promotion/index.js",
    "build:get-promotions": "esbuild lambda/get-promotions.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/get-promotions/index.js",
    "build:get-promotion-by-id": "esbuild lambda/get-promotion-by-id.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/get-promotion-by-id/index.js",
    "build:update-promotion": "esbuild lambda/update-promotion.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/update-promotion/index.js",
    "build:delete-promotion": "esbuild lambda/delete-promotion.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/delete-promotion/index.js",
    "build:search": "esbuild lambda/search.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/search/index.js",
    "build:create-match": "esbuild lambda/create-match.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/create-match/index.js",
    "build:get-matches": "esbuild lambda/get-matches.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/get-matches/index.js",
    "build:get-match-by-id": "esbuild lambda/get-match-by-id.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/get-match-by-id/index.js",
    "build:delete-match": "esbuild lambda/delete-match.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/delete-match/index.js",
    "build:update-match": "esbuild lambda/update-match.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/update-match/index.js",
    "build:update-participant-rating": "esbuild lambda/update-participant-rating.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/update-participant-rating/index.js",
    "build:update-overall-match-rating": "esbuild lambda/update-overall-match-rating.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/update-overall-match-rating/index.js",
    "build:get-wrestler-years": "esbuild lambda/get-wrestler-years.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/get-wrestler-years/index.js",
    "build:get-year-standings": "esbuild lambda/get-year-standings.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/get-year-standings/index.js",
    "build:get-years": "esbuild lambda/get-years.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/get-years/index.js",
    "build:assign-tier": "esbuild lambda/assign-tier.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/assign-tier/index.js",
    "build:recompute-wrestler-year": "esbuild lambda/recompute-wrestler-year.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/recompute-wrestler-year/index.js",
    "build:recompute-career-score": "esbuild lambda/recompute-career-score.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/recompute-career-score/index.js",
    "build:get-career-leaderboard": "esbuild lambda/get-career-leaderboard.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/get-career-leaderboard/index.js",
    "test": "jest --passWithNoTests",
    "cdk": "npx cdk",
    "synth": "rm -rf ./build/cdk.out && npx cdk synth -q -o ./build/cdk.out",
    "synth-vars": "npx dotenv -e .env -- npm run synth",
    "deploy": "npx cdk deploy -a ./build/cdk.out"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^22.7.9",
    "aws-cdk": "^2.1020.2",
    "dotenv-cli": "^11.0.0",
    "esbuild": "^0.25.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.17.0",
    "@clerk/backend": "^3.2.3",
    "@types/aws-lambda": "^8.10.147",
    "aws-cdk-lib": "^2.180.0",
    "constructs": "^10.4.2",
    "mongoose": "^8.16.1"
  }
}
